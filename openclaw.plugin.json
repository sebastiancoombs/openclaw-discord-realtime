{
  "id": "discord-realtime",
  "name": "Discord Realtime Voice",
  "description": "Voice bridge: Discord voice channel ↔ OpenAI Realtime API with tool calling",
  "configSchema": {
    "type": "object",
    "properties": {
      "followUserIds": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Discord user IDs to auto-follow into voice channels"
      },
      "voice": {
        "type": "string",
        "default": "coral",
        "description": "OpenAI Realtime TTS voice"
      },
      "model": {
        "type": "string",
        "default": "gpt-4o-realtime-preview",
        "description": "OpenAI Realtime model"
      },
      "systemPrompt": {
        "type": "string",
        "description": "System instructions for the voice assistant"
      },
      "turnDetection": {
        "type": "string",
        "enum": ["server_vad", "semantic_vad"],
        "default": "semantic_vad"
      },
      "transcriptDir": {
        "type": "string",
        "description": "Directory for saving voice transcripts"
      }
    },
    "additionalProperties": false
  }
}
