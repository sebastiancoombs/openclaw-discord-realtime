{
  "id": "discord-realtime",
  "name": "Discord Realtime Voice",
  "description": "Sub-500ms voice control via Discord voice channels using OpenAI Realtime API",
  "configSchema": {
    "type": "object",
    "properties": {
      "provider": { "type": "string", "enum": ["openai-realtime", "elevenlabs", "cascade"], "default": "openai-realtime" },
      "systemPrompt": { "type": "string" },
      "voice": { "type": "string", "default": "coral" },
      "model": { "type": "string", "default": "gpt-4o-realtime-preview" },
      "turnDetection": { "type": "string", "default": "server_vad" },
      "tools": { "type": "array", "items": { "type": "object" } },
      "followUserIds": { "type": "array", "items": { "type": "string" } },
      "transcriptDir": { "type": "string" },
      "memory": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "loadPreviousSessions": { "type": "integer", "default": 3 },
          "maxContextTurns": { "type": "integer", "default": 10 }
        }
      },
      "history": {
        "type": "object",
        "properties": {
          "maxTurns": { "type": "integer", "default": 50 }
        }
      }
    },
    "additionalProperties": true
  }
}
