# ── Required ──────────────────────────────────────────────────────────────────

# Discord bot token
DISCORD_BOT_TOKEN=your-discord-bot-token

# OpenAI API key (required for openai-realtime provider and elevenlabs/openai LLM)
OPENAI_API_KEY=sk-proj-...

# ── Provider: elevenlabs ───────────────────────────────────────────────────────
# Required when config.json "provider" is "elevenlabs"

ELEVENLABS_API_KEY=

# Required when config.json "llmProvider" is "anthropic"
ANTHROPIC_API_KEY=

# ── Provider: cascade ──────────────────────────────────────────────────────────
# Required when cascade STT is "deepgram"
DEEPGRAM_API_KEY=

# Required when cascade LLM is "groq"
GROQ_API_KEY=

# ── Discord auto-join (optional) ───────────────────────────────────────────────

# Voice channel to auto-join on startup
DISCORD_VOICE_CHANNEL_ID=

# Guild (server) ID for auto-join
DISCORD_GUILD_ID=

# Only listen to this user's audio (optional, listens to all if not set)
DISCORD_LISTEN_USER_ID=

# ── Env overrides (optional — prefer setting these in config.json) ─────────────

# Override model from config.json
OPENAI_REALTIME_MODEL=gpt-realtime

# Override voice from config.json
OPENAI_VOICE=coral
