{
  "tools": [
    {
      "name": "get_time",
      "description": "Get the current UTC time.",
      "endpoint": { "method": "GET", "url": "http://worldtimeapi.org/api/timezone/UTC" },
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_weather",
      "description": "Get current weather for a location.",
      "endpoint": { "method": "GET", "url": "https://your-service.example.com/weather" },
      "parameters": {
        "type": "object",
        "properties": {
          "location": { "type": "string", "description": "City name or location" }
        },
        "required": ["location"]
      }
    },
    {
      "name": "run_action",
      "description": "Run a custom action on your backend service.",
      "endpoint": { "method": "POST", "url": "https://your-service.example.com/action" },
      "parameters": {
        "type": "object",
        "properties": {
          "action": { "type": "string", "description": "The action to perform" },
          "target": { "type": "string", "description": "The target to act on" }
        },
        "required": ["action"]
      }
    }
  ]
}
